<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:contentDescription="@string/my_image_desc"
        android:src="@drawable/my"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:background="#EDE9CA"
        android:text="Prachi Sudesh Chougale"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="#CEDCDB"
        android:text="@string/my_email"
        android:textColor="@color/black"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/collegeLabel"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:background="#E6C1C1"
            android:text="@string/college_label"
            android:textColor="@color/black"
            tools:ignore="TextSizeCheck" />

        <EditText
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:autofillHints="organizationName"
            android:backgroundTint="#D35757"
            android:inputType="text"
            android:labelFor="@id/collegeLabel"
            android:text="@string/dyp"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/branchLabel"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:background="#97B4C1"
            android:text="@string/b"
            android:textColor="@color/black" />

        <EditText
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:autofillHints="none"
            android:backgroundTint="#206889"
            android:inputType="text"
            android:labelFor="@id/branchLabel"
            android:text="@string/cs"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/classLabel"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:background="#BA94C1"
            android:text="@string/t"
            android:textColor="@color/black" />

        <EditText
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:autofillHints="none"
            android:backgroundTint="#9C27B0"
            android:inputType="text"
            android:labelFor="@id/classLabel"
            android:text="@string/ty"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/phoneLabel"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:background="#C1889B"
            android:text="@string/ph"
            android:textColor="#263238" />

        <EditText
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:autofillHints="phone"
            android:backgroundTint="#E91E63"
            android:inputType="phone"
            android:labelFor="@id/phoneLabel"
            android:text="@string/num"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

    <Button
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2196F3"
        android:text="@string/sub" />

    <Button
        android:id="@+id/backBtn"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#3F51B5"
        android:text="@string/login_back" />

</LinearLayout>
